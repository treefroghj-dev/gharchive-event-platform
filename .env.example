# GCP project
#test
GHARCHIVE_GCP_PROJECT_ID=your-gcp-project-id

#GHARCHIVE_GCP_PROJECT_ID=your-gcp-project-id
GHARCHIVE_GCP_REGION=your-gcp-region

# Dataproc Serverless (Airflow DataprocCreateBatchOperator); required for transform tasks
#for example, 'your-sa@your-project-id.iam.gserviceaccount.com'
GHARCHIVE_DATAPROC_SERVICE_ACCOUNT=your-service-account-email

# Local credential file path on your machine
GHARCHIVE_GOOGLE_APPLICATION_CREDENTIALS_LOCAL=your-local-credential-file-path

# GCS
GHARCHIVE_GCS_BUCKET_NAME=gharchive-events-platform-raw-dev
GHARCHIVE_GCS_RAW_PREFIX=gharchive/raw
GHARCHIVE_GCS_PROCESSED_PREFIX=gharchive/processed

# Bigquery
GHARCHIVE_BQ_DATASET=gh_events_trends_dev

# Partition date = logical ds minus this many days (align with GH Archive publish lag)
GHARCHIVE_PIPELINE_DATA_DATE_LAG_DAYS=1

