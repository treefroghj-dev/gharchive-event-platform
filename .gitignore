# Virtual environments (large)
.venv/
venv/
ENV/
env/

# --- Environment & secrets (keep *.example committed) ---
.env
.env.*
!.env.example
*.pem
*.key
*.p12
*.pfx
**/secrets/
airflow/keys/

# Airflow / Docker Compose local overrides
airflow/.env
docker-compose.override.yaml
docker-compose.override.yml

# --- Google Cloud / OAuth (sensitive; often large JSON) ---
application_default_credentials.json
client_secret*.json
credentials.json
**/gcp-key.json
*-service-account*.json

# SSH private keys (if ever placed in the repo by mistake)
id_rsa
id_ed25519
id_ecdsa

# --- Local datasets & downloads (large) ---
# Raw GHArchive hour files under ingestion (often 100MB+)
src/gharchive_events/ingestion/*.json
data/
datas/
raw/
downloads/
*.parquet
*.csv.gz
*.json.gz
*.ndjson
*.ndjson.gz

# Logs & runtime output
logs/
*.log
transform_debug.log
**/transform_debug.log

# --- dbt (artifacts; profiles.yml uses env_var only and is committed) ---
gharchive_dbt/.user.yml
**/target/
**/dbt_packages/
dbt.log

# --- Terraform (state is sensitive; .tfvars often has IDs) ---
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!terraform/terraform.tfvars
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --- Spark / Hive local metadata ---
metastore_db/
spark-warehouse/
derby.log

# --- Jupyter ---
.ipynb_checkpoints/

# --- Optional local library path (not part of source tree) ---
lib/

# --- IDE / OS ---
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store
Thumbs.db
